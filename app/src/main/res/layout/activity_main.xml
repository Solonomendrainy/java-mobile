<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- Header avec fond bleu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2196F3"
            android:padding="15dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 GESTION DES ÉTUDIANTS"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Système de gestion académique"
                android:textSize="12sp"
                android:textColor="#E0E0E0"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Formulaire avec fond blanc et bordures arrondies -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:layout_marginBottom="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️ Informations de l'étudiant"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/txtNumEt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔢 Numéro étudiant"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/txtNom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Nom complet"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/txtMoyenne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="⭐ Moyenne (0-20)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:background="#F5F5F5"/>
        </LinearLayout>

        <!-- Boutons d'action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">

            <Button
                android:id="@+id/btnAjouter"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="➕ Ajouter"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="10sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="5dp"/>

            <Button
                android:id="@+id/btnModifier"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="✏️ Modifier"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#2196F3"
                android:textSize="10sp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"/>

            <Button
                android:id="@+id/btnSupprimer"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🗑️Supprimer"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#F44336"
                android:textSize="9sp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"/>
        </LinearLayout>
        <!-- Liste des étudiants avec en-têtes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Liste des étudiants"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:padding="8dp"/>

            <!-- En-têtes du tableau -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2196F3"
                android:padding="12dp"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NUMÉRO"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="NOM"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MOYENNE"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Liste des étudiants -->
            <ListView
                android:id="@+id/listEtudiants"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp" />
        </LinearLayout>

        <!-- Statistiques -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:layout_marginBottom="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Statistiques"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📈 Moyenne Classe :"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/txtMoyClasse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📉 Moyenne Minimale :"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/txtMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Moyenne Maximale :"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/txtMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bouton Graphique -->
        <Button
            android:id="@+id/btnGraphique"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📊 Afficher le Graphique détaillé"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="#9C27B0"/>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>